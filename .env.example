# Copy this file to .env and fill in values before starting the app.
# Never commit .env to version control.

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me
JWT_SECRET_KEY=change-me

# ── Flask ─────────────────────────────────────────────────────────────────────
# development | production | testing
FLASK_ENV=production

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://bennu:bennu@postgres:5432/bennu

# ── Redis (Celery broker + rate limiter) ──────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://ollama:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2:3b

# ── File uploads ──────────────────────────────────────────────────────────────
# Default: /app/uploads (inside the container)
# UPLOAD_FOLDER=/app/uploads

# ── Frontend ──────────────────────────────────────────────────────────────────
# Path to the built React app (npm run build output)
FRONTEND_DIST=/app/dist

# ── Testing ───────────────────────────────────────────────────────────────────
# Only needed when running the test suite
# TEST_DATABASE_URL=postgresql://bennu:bennu@postgres:5432/bennu_test
